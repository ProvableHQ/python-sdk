    assert.eq r17 true;
    ternary r1.hop0.zero_for_one r10.token0 r10.token1 into r18;
    ternary r1.hop0.zero_for_one r10.token1 r10.token0 into r19;
    is.eq r18 r1.token_in into r20;
    assert.eq r20 true;
    get slots[r1.hop0.pool] into r21;
    cast r10.fee into r22 as u32;
