finalize swap_multi_hop:
    input r0 as dynamic.future;
    input r1 as SwapMultiHopRequest.public;
    input r2 as field.public;
    await r0;
    lte block.height r1.deadline into r3;
    assert.eq r3 true;
    gte r1.hop_count 2u8 into r4;
